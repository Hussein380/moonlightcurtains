# Live MongoDB Atlas Connection String
DATABASE_URL="mongodb+srv://<username>:<password>@cluster0.mongodb.net/moonlightcurtains?retryWrites=true&w=majority"

# JWT Secret for Admin Authentication (Must be strong and unguessable)
NEXTAUTH_SECRET="your_very_long_secure_random_string_here"

# Cloudinary Credentials for image uploads
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Express Server Port (Render will automatically set this, but useful for local)
PORT=5000
